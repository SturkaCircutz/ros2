<?xml version="1.0"?>
<robot name="tiny_diffbot">
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.22 0.12"/>
      </geometry>
      <material name="body_blue">
        <color rgba="0.1 0.35 0.8 1"/>
      </material>
    </visual>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.035"/>
      </geometry>
      <material name="wheel_dark">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>
  </link>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.035"/>
      </geometry>
      <material name="wheel_dark">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>
  </link>

  <link name="front_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="caster_gray">
        <color rgba="0.6 0.6 0.6 1"/>
      </material>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.13 0.055" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.13 0.055" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.13 0 0.025" rpy="0 0 0"/>
  </joint>
</robot>

